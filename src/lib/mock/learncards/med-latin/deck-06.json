      },
      "correctAnswer": "the first part (prefix/root/combining form)",
      "options": [
        "the last part again",
        "the first part (prefix/root/combining form)",
        "the middle only",
        "the translation"
      ],
      "explanation": {
        "en": "Handout method. (Exercise III, p.16)"
      }
    },
