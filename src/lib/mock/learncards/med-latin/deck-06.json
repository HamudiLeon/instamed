      "cardId": "s3-3043",
      "type": "mcq",
      "question": {
        "en": "In defining a term, step 1 is usually to define:"
      },
      "correctAnswer": "the suffix (last part)",
      "options": [
        "the prefix",
        "the root",
        "the suffix (last part)",
        "the middle first"
      ],
      "explanation": {
        "en": "Handout 3-step defining method. (Exercise III, p.16)"
